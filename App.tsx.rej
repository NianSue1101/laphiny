-function findPreviousUserMessageIndex(messages: ChatMessage[], startIndex: number): number {
-  for (let index = startIndex - 1; index >= 0; index -= 1) {
-    if (messages[index]?.authorId === 'user') return index;
-  }
-  return -1;
-}
