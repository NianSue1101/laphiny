{
  "name": "laphiny",
  "version": "0.36.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "android:assemble": "npm run android:assemble:debug",
    "android:assemble:debug": "node scripts/run-gradle.mjs assembleDebug",
    "android:assemble:release": "node scripts/run-gradle.mjs assembleRelease",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "web:build": "expo export --platform web && node scripts/fix-web-paths.mjs",
    "web:preview": "npm run web:build && node scripts/preview-web.mjs",
    "sync:server": "node scripts/sync-server.mjs",
    "feedback:server": "node scripts/feedback-server.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node --test --import tsx tests/*.test.ts"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "baseline-browser-mapping": "^2.10.40",
    "expo": "~54.0.3",
    "expo-build-properties": "~1.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-document-picker": "~14.0.7",
    "expo-file-system": "~19.0.17",
    "expo-font": "~14.0.12",
    "expo-image-picker": "~17.0.8",
    "expo-notifications": "~0.32.17",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "@types/react": "~19.1.10",
    "tsx": "^4.20.3",
    "typescript": "~5.9.2"
  }
}
